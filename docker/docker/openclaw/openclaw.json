{
  "gateway": {
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": ["*"],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true
    },
    "auth": {
      "mode": "token",
      "token": "123456"
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "api": "ollama",
        "baseUrl": "http://host.docker.internal:11434",
        "apiKey": "${OLLAMA_API_KEY}",
        "models": [
          {
            "id": "qwen3.5:0.8b",
            "name": "qwen3.5:0.8b",
            "input": ["text"],
            "contextWindow": 16384,
            "maxTokens": 8192
          },
          {
            "id": "qwen3.5:4b",
            "name": "qwen3.5:4b",
            "input": ["text"],
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      },
      "dashscope": {
        "api": "openai-completions",
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "apiKey": "${ALI_BAILIAN_DASHSCOPE_API_KEY}",
        "models": [
          {
            "id": "qwen3-vl-flash-2026-01-22",
            "name": "qwen3-vl-flash-2026-01-22",
            "input": ["text", "image"],
            "compat": { "supportsDeveloperRole": false },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "dashscope/qwen3-vl-flash-2026-01-22"
      }
    }
  }
}
